# NLP Sentiment Analysis - Environment Configuration
# Copy this file to .env and configure your settings

# =============================================================================
# Application Settings
# =============================================================================

# Environment: development, staging, production
APP_ENV=development

# Debug mode (set to false in production)
DEBUG=true

# =============================================================================
# Data Settings
# =============================================================================

# Number of reviews to load on Streamlit Cloud
CLOUD_SAMPLE_SIZE=30000

# Force data reload on startup (useful for development)
FORCE_DATA_RELOAD=false

# =============================================================================
# API Settings
# =============================================================================

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# Enable API authentication (optional)
API_AUTH_ENABLED=false
API_KEY=your-secret-api-key-here

# Rate limiting (requests per minute)
RATE_LIMIT_RPM=60

# =============================================================================
# Streamlit Settings
# =============================================================================

# Streamlit server configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true

# =============================================================================
# Logging Settings
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=text

# Log file path (leave empty to disable file logging)
LOG_FILE=logs/app.log

# =============================================================================
# Model Settings
# =============================================================================

# Default model for predictions
DEFAULT_MODEL=logistic_regression

# Enable transformer models (requires GPU for reasonable speed)
ENABLE_TRANSFORMERS=false

# =============================================================================
# External Services (Optional)
# =============================================================================

# HuggingFace token (for private datasets, optional)
# HUGGINGFACE_TOKEN=your-token-here

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=your-sentry-dsn-here
